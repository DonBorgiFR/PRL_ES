# Puerto y host del backend
PORT=4173
HOST=0.0.0.0

# CORS para frontend (usa * solo en entornos controlados)
CORS_ORIGIN=*

# Proveedor principal (Ollama local o remoto)
OLLAMA_BASE_URL=http://127.0.0.1:11434
OLLAMA_API_PREFIX=/api

# Fallback opcional (modelo externo o segundo Ollama)
OLLAMA_FALLBACK_URL=

# Proteccion del endpoint interno /api/ollama (Bearer token opcional)
OLLAMA_PROXY_TOKEN=

# Token que el backend envia al proveedor externo si aplica
OLLAMA_UPSTREAM_TOKEN=
