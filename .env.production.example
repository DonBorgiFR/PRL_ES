# Entorno productivo (plantilla segura)
NODE_ENV=production

# Backend
PORT=4173
HOST=0.0.0.0

# CORS: usar uno o varios orígenes separados por coma
# Ejemplo: https://prl.empresa.es,https://intranet.empresa.es
CORS_ORIGIN=https://prl.empresa.es

# Proveedor principal de IA
OLLAMA_BASE_URL=http://10.0.0.25:11434
OLLAMA_API_PREFIX=/api

# Fallback opcional (vacío si no aplica)
OLLAMA_FALLBACK_URL=

# Seguridad endpoint interno
OLLAMA_PROXY_TOKEN=cambiar-por-token-largo-y-unico

# Token hacia proveedor externo (si aplica)
OLLAMA_UPSTREAM_TOKEN=
